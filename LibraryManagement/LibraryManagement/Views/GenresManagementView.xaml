<Window x:Class="LibraryManagement.Views.GenresManagementView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GenresGrid" 
                  ItemsSource="{Binding Genres.Local}"
                  AutoGenerateColumns="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Добавить" Click="AddGenre_Click" Margin="5" Padding="15,5" Background="#4CAF50" Foreground="White"/>
            <Button Content="Удалить" Click="DeleteGenre_Click" Margin="5" Padding="15,5" Background="#F44336" Foreground="White"/>
            <Button Content="Сохранить" Click="Save_Click" Margin="5" Padding="15,5" Background="#2196F3" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>